<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>Cyber-Reverse Neon Player</title>
    <style>
        :root {
            --neon-red: #ff003c;
            --neon-glow: rgba(255, 0, 60, 0.7);
            --dark-bg: #050505;
        }

        body {
            background-color: var(--dark-bg);
            color: #fff;
            font-family: 'Segoe UI', 'Courier New', monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .player-card {
            background: #111;
            padding: 3rem;
            border-radius: 20px;
            border: 1px solid #333;
            box-shadow: 0 0 50px rgba(0,0,0,1);
            text-align: center;
            width: 450px;
        }

        h1 {
            color: var(--neon-red);
            text-shadow: 0 0 10px var(--neon-red);
            letter-spacing: 3px;
            margin-bottom: 2rem;
            font-size: 1.5rem;
        }

        /* 連續控制區：旋鈕 */
        .knob-container {
            display: flex;
            justify-content: space-around;
            margin-bottom: 3rem;
        }

        .knob-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }

        .neon-knob {
            width: 120px;
            height: 120px;
            border: 4px solid var(--neon-red);
            border-radius: 50%;
            position: relative;
            cursor: grab;
            box-shadow: 0 0 15px var(--neon-red), inset 0 0 15px var(--neon-red);
            transition: box-shadow 0.2s;
        }

        .neon-knob::after {
            content: '';
            position: absolute;
            top: 10px;
            left: 50%;
            width: 4px;
            height: 25px;
            background: var(--neon-red);
            box-shadow: 0 0 8px var(--neon-red);
            transform: translateX(-50%);
        }

        .label {
            font-size: 0.7rem;
            color: #888;
            text-transform: uppercase;
        }

        /* 離散控制區：音量方塊 */
        .discrete-section {
            border-top: 1px solid #333;
            padding-top: 2rem;
        }

        .volume-grid {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
        }

        .vol-step {
            width: 50px;
            height: 40px;
            border: 2px solid #333;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-weight: bold;
            color: #444;
            transition: all 0.05s; /* 縮短過渡，強化離散感 */
        }

        .vol-step.active {
            color: #fff;
            border-color: var(--neon-red);
            background: rgba(255, 0, 60, 0.2);
            box-shadow: 0 0 20px var(--neon-red);
            text-shadow: 0 0 5px #fff;
        }

        #status-text {
            margin-top: 20px;
            font-size: 0.9rem;
            color: var(--neon-red);
            height: 20px;
        }
    </style>
</head>
<body>

<div class="player-card">
    <h1 id="title">LOGIC REVERSAL</h1>

    <div class="knob-container">
        <div class="knob-wrapper">
            <div id="status-knob" class="neon-knob"></div>
            <div class="label">Status (Continuous)</div>
        </div>
        <div class="knob-wrapper">
            <div id="seek-knob" class="neon-knob" style="border-color: #00f3ff; box-shadow: 0 0 15px #00f3ff, inset 0 0 15px #00f3ff;"></div>
            <div class="label">Seek (Continuous)</div>
        </div>
    </div>

    <div class="discrete-section">
        <div class="label">Volume Steps (Discrete)</div>
        <div class="volume-grid">
            <div class="vol-step" data-vol="0.1">1</div>
            <div class="vol-step" data-vol="0.3">2</div>
            <div class="vol-step active" data-vol="0.5">3</div>
            <div class="vol-step" data-vol="0.7">4</div>
            <div class="vol-step" data-vol="1.0">5</div>
        </div>
    </div>

    <div id="status-text">SYSTEM READY</div>
</div>

<audio id="main-audio" loop>
    <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<script>
    const audio = document.getElementById('main-audio');
    const statusKnob = document.getElementById('status-knob');
    const seekKnob = document.getElementById('seek-knob');
    const volSteps = document.querySelectorAll('.vol-step');
    const statusText = document.getElementById('status-text');

    let isDraggingStatus = false;
    let isDraggingSeek = false;

    // --- 離散控制：音量 ---
    // 按下瞬間直接跳轉，不設定淡入淡出
    volSteps.forEach(step => {
        step.addEventListener('click', () => {
            volSteps.forEach(s => s.classList.remove('active'));
            step.classList.add('active');
            
            const vol = parseFloat(step.dataset.vol);
            audio.volume = vol; // 離散輸出
            statusText.innerText = `VOLUME SET TO: ${vol * 100}%`;
        });
    });

    // --- 連續控制：通用旋轉邏輯 ---
    function getAngle(event, element) {
        const rect = element.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const x = (event.clientX || event.touches[0].clientX) - centerX;
        const y = (event.clientY || event.touches[0].clientY) - centerY;
        let angle = Math.atan2(y, x) * (180 / Math.PI);
        return angle + 90; // 修正起始角度
    }

    // 播放狀態旋鈕 (Status)
    statusKnob.addEventListener('mousedown', () => isDraggingStatus = true);
    window.addEventListener('mouseup', () => isDraggingStatus = false);

    window.addEventListener('mousemove', (e) => {
        if (!isDraggingStatus) return;
        
        const angle = getAngle(e, statusKnob);
        statusKnob.style.transform = `rotate(${angle}deg)`;
        
        // 連續輸出邏輯：角度大於 20 度開始播放，角度越大速度越快 (0.5x ~ 2.0x)
        if (angle > 20) {
            const speed = Math.min(2, Math.max(0.5, angle / 100));
            audio.playbackRate = speed;
            if (audio.paused) audio.play();
            statusText.innerText = `PLAYING: ${speed.toFixed(2)}x SPEED`;
        } else {
            audio.pause();
            statusText.innerText = `PAUSED / STOPPED`;
        }
    });

    // 快轉旋鈕 (Seek)
    seekKnob.addEventListener('mousedown', () => isDraggingSeek = true);
    window.addEventListener('mouseup', () => isDraggingSeek = false);

    window.addEventListener('mousemove', (e) => {
        if (!isDraggingSeek) return;
        
        const angle = getAngle(e, seekKnob);
        seekKnob.style.transform = `rotate(${angle}deg)`;
        
        // 連續輸出邏輯：旋轉角度直接對應歌曲百分比
        const percent = (angle % 360) / 360;
        if (percent >= 0) {
            audio.currentTime = percent * audio.duration;
            statusText.innerText = `SEEKING: ${Math.floor(percent * 100)}%`;
        }
    });

    // 初始化音量
    audio.volume = 0.5;
</script>

</body>
</html>
